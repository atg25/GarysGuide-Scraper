# Staging Environment Configuration
# Copy to .env.staging and customize for your deployment

# MCP Server Settings
GARYS_EVENTS_MCP_ENABLED=true
GARYS_EVENTS_MCP_FAIL_OPEN=true

# REST API Backend (where the MCP server will fetch events from)
# For local testing, use http://localhost:9001 (mock API)
# For production staging, use actual API URL with credentials
GARYS_EVENTS_REST_API_BASE_URL=http://localhost:9001

# API Response Timeout (milliseconds)
GARYS_EVENTS_REST_API_TIMEOUT_MS=5000

# MCP Server Repository Path (required for MCP to locate the tool)
GARYS_EVENTS_MCP_REPO_PATH=/Users/agard/NJIT/IS421/PyPack_GarysGuide

# Docker Compose Overrides
COMPOSE_PROJECT_NAME=garys-events-staging
