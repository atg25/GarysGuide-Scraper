# DigitalOcean Deployment Configuration
# Copy to .env.do and fill in values

# API security token (used for Authorization: Bearer header)
API_TOKEN=your-secret-token-here

# Database path (will be persisted via Docker volume)
DB_PATH=/app/garys_events.db

# REST API base URL (used by MCP tool to call itself)
GARYS_EVENTS_REST_API_BASE_URL=http://142.93.3.242:8000

# Enable MCP server at /mcp endpoint
GARYS_EVENTS_MCP_ENABLED=true
